# =============================================================================
# config.env — Build-time configuration for WSL image customization
#
# This file is sourced by apply-customizations.sh before any customization
# steps run. Variables defined here are available to all hook scripts in
# customizations/scripts/.
#
# Do NOT store secrets here — use GitHub Actions secrets instead.
# =============================================================================

# ── Organization identity ─────────────────────────────────────────────────────

# Display name used in MOTD and shell prompts
ORG_NAME="My Organization"

# Short slug used for file/directory naming (no spaces)
ORG_SLUG="myorg"

# Contact info shown in MOTD
ORG_CONTACT="it-support@example.com"

# ── Locale and timezone ───────────────────────────────────────────────────────

# System locale
LOCALE="en_US.UTF-8"

# System timezone (see `timedatectl list-timezones`)
TIMEZONE="America/New_York"

# ── Default user ──────────────────────────────────────────────────────────────

# Set to "true" to create a default non-root user
CREATE_DEFAULT_USER="false"

# Default username (used if CREATE_DEFAULT_USER=true)
DEFAULT_USERNAME="wsluser"

# Default shell for the user
DEFAULT_SHELL="/bin/bash"

# ── APT configuration ─────────────────────────────────────────────────────────

# Additional APT mirror (leave blank to use Ubuntu defaults)
# APT_MIRROR="http://us.archive.ubuntu.com/ubuntu"

# HTTP proxy for APT (leave blank for direct access)
# APT_HTTP_PROXY="http://proxy.example.com:3128"

# ── WSL-specific configuration ────────────────────────────────────────────────

# Default WSL.conf settings (written to /etc/wsl.conf in the image)
WSL_AUTOMOUNT="true"
WSL_AUTOMOUNT_ROOT="/mnt"
WSL_AUTOMOUNT_OPTIONS="metadata,umask=22,fmask=11"
WSL_NETWORK_GENERATE_HOSTS="true"
WSL_NETWORK_GENERATE_RESOLV_CONF="true"
WSL_INTEROP_ENABLED="true"
WSL_INTEROP_APPENDWINDOWSPATH="false"
